# Supabase - Development
NEXT_PUBLIC_SUPABASE_URL=https://your-dev-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_dev_anon_key

# Supabase - Staging/Beta
# NEXT_PUBLIC_SUPABASE_URL=https://your-beta-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_beta_anon_key

# Supabase - Production
# NEXT_PUBLIC_SUPABASE_URL=https://your-prod-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_prod_anon_key

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Payment Gateway (PayFast)
NEXT_PUBLIC_PAYFAST_MERCHANT_ID=10000100
NEXT_PUBLIC_PAYFAST_MERCHANT_KEY=46f0cd694581a
PAYFAST_PASSPHRASE=your_passphrase
PAYFAST_SANDBOX=true

# Payment Gateway (Yoco)
NEXT_PUBLIC_YOCO_PUBLIC_KEY=pk_test_xxx
YOCO_SECRET_KEY=sk_test_xxx

# Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
